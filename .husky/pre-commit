#!/bin/sh

# Exit on any error
set -e

bun run build

bun test

# Format staged files only.
#
# lint-staged reads the config already in package.json, runs `ultracite fix`
# against just the staged paths, and handles stashing/restoring unstaged work
# itself.
#
# This replaces a hand-rolled stash/restore block that ran `ultracite fix` over
# the WHOLE repo and ended in `exit $FORMAT_EXIT_CODE`. With pre-existing lint
# errors elsewhere in the tree, that call always exited non-zero, so every
# commit was rejected no matter what was staged.
bun x lint-staged
